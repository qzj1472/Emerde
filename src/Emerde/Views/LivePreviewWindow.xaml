<ui:FluentWindow x:Class="Emerde.Views.LivePreviewWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:views="clr-namespace:Emerde.Views"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="{I18N LivePreview}"
                 Width="960"
                 Height="600"
                 MinWidth="520"
                 MinHeight="360"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="CanResize"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterOwner">
    <Grid x:Name="WindowRoot">
        <views:LivePreviewPanel x:Name="PreviewContent" Margin="8,42,8,8" />
        <ui:TitleBar x:Name="WindowTitleBar"
                     Title="{I18N LivePreview}"
                     CanMaximize="True"
                     ShowClose="True"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Favicon.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
    </Grid>
</ui:FluentWindow>
