<ui:FluentWindow x:Class="Emerde.Views.ScreenRecordListWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
                 xmlns:local="clr-namespace:Emerde.Views"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="视频列表"
                 Width="1032"
                 Height="720"
                 d:Background="#FF101010"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterOwner"
                 mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <Style x:Key="VideoListToolbarButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="VideoListIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="VideoMetaChipStyle" TargetType="{x:Type Border}">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="CornerRadius" Value="{StaticResource Win11ControlCornerRadius}" />
            <Setter Property="Background" Value="#18337DFF" />
            <Setter Property="BorderBrush" Value="#30337DFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="VideoMetaChipTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid x:Name="VideoListContentRoot" Margin="14,48,14,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:StackPanel Grid.Column="0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Orientation="Horizontal"
                               Spacing="8">
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource VideoListToolbarButtonStyle}">
                        <ui:StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Sync}" />
                            <TextBlock Text="刷新" />
                        </ui:StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleSortCommand}"
                            Style="{StaticResource VideoListToolbarButtonStyle}">
                        <ui:StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}">
                                <ui:FontIcon.Style>
                                    <Style TargetType="{x:Type ui:FontIcon}">
                                        <Setter Property="Glyph" Value="{x:Static ui:FontSymbols.ChevronUp}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSortDescending}" Value="True">
                                                <Setter Property="Glyph" Value="{x:Static ui:FontSymbols.ChevronDown}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:FontIcon.Style>
                            </ui:FontIcon>
                            <TextBlock Text="{Binding SortDirectionText}" />
                        </ui:StackPanel>
                    </Button>
                    <Button Command="{Binding ImportFolderCommand}"
                            Style="{StaticResource VideoListToolbarButtonStyle}">
                        <ui:StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                            <TextBlock Text="导入" />
                        </ui:StackPanel>
                    </Button>
                </ui:StackPanel>

                <ui:StackPanel Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Orientation="Horizontal"
                               Spacing="8">
                    <ui:StackPanel Orientation="Horizontal"
                                   Spacing="8"
                                   HorizontalAlignment="Right">
                        <ui:StackPanel.Style>
                            <Style TargetType="{x:Type ui:StackPanel}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:StackPanel.Style>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SelectedVideoSummary}" />
                        <Button Command="{Binding MergeSelectedCommand}"
                                IsEnabled="{Binding HasSelectedVideos}"
                                Style="{StaticResource VideoListIconButtonStyle}"
                                ToolTip="合并">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Link}" />
                        </Button>
                        <Button Command="{Binding DeleteSelectedCommand}"
                                IsEnabled="{Binding HasSelectedVideos}"
                                Style="{StaticResource VideoListIconButtonStyle}"
                                ToolTip="删除">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Delete}" />
                        </Button>
                        <Button Command="{Binding MoveSelectedCommand}"
                                IsEnabled="{Binding HasSelectedVideos}"
                                Style="{StaticResource VideoListIconButtonStyle}"
                                ToolTip="移动">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                        </Button>
                        <Button Command="{Binding CopySelectedCommand}"
                                IsEnabled="{Binding HasSelectedVideos}"
                                Style="{StaticResource VideoListIconButtonStyle}"
                                ToolTip="复制">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Copy}" />
                        </Button>
                        <Button Command="{Binding SelectAllCommand}"
                                Style="{StaticResource VideoListIconButtonStyle}"
                                ToolTip="全选">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Accept}" />
                        </Button>
                        <Button Command="{Binding InvertSelectionCommand}"
                                Style="{StaticResource VideoListIconButtonStyle}"
                                ToolTip="反选">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Switch}" />
                        </Button>
                        <Button Command="{Binding CancelMultiSelectCommand}"
                                Style="{StaticResource VideoListIconButtonStyle}"
                                ToolTip="取消">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                        </Button>
                    </ui:StackPanel>
                    <Button Command="{Binding ToggleMultiSelectCommand}">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource VideoListToolbarButtonStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <ui:StackPanel Orientation="Horizontal" Spacing="7">
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         Glyph="{x:Static ui:FontSymbols.Accept}" />
                            <TextBlock Text="多选" />
                        </ui:StackPanel>
                    </Button>
                </ui:StackPanel>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Videos}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="VideoCardShell"
                                Margin="2,8,10,0"
                                Padding="12"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource Win11ControlCornerRadius}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="146" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="128"
                                        Height="72"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="#16000000"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Win11ControlCornerRadius}"
                                        ClipToBounds="True">
                                    <ui:FontIcon HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                 FontSize="24"
                                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Video}" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding FileName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <ui:StackPanel Margin="0,10,0,0"
                                                   Orientation="Horizontal"
                                                   Spacing="0">
                                        <Border MaxWidth="220" Style="{StaticResource VideoMetaChipStyle}">
                                            <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                       Text="{Binding NickName}" />
                                        </Border>
                                        <Border MaxWidth="160" Style="{StaticResource VideoMetaChipStyle}">
                                            <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                       Text="{Binding Resolution}" />
                                        </Border>
                                        <Border MaxWidth="150" Style="{StaticResource VideoMetaChipStyle}">
                                            <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                       Text="{Binding Bitrate}" />
                                        </Border>
                                    </ui:StackPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding DataContext.OpenVideoCommand, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="打开视频" />
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding DataContext.TranscodeVideoCommand, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="转码">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanTranscode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding DataContext.SplitVideoCommand, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="分割" />
                                    <Button Command="{Binding DataContext.OpenDirectoryCommand, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="打开目录" />
                                </StackPanel>

                                <CheckBox Grid.Column="3"
                                          Margin="14,0,0,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                    <CheckBox.Style>
                                        <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsMultiSelectMode, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="VideoCardShell" Property="Background" Value="#2A4DA7B0" />
                                <Setter TargetName="VideoCardShell" Property="BorderBrush" Value="#884DA7B0" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid>
            <ui:TitleBar Title="视频列表" ShowMaximize="False">
                <ui:TitleBar.Icon>
                    <ui:SymbolIcon Symbol="Video24" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Grid>

        <Grid x:Name="VideoListDialogOverlay"
              Background="Transparent"
              IsHitTestVisible="False"
              Panel.ZIndex="35"
              Visibility="Collapsed" />

        <Grid x:Name="VideoListModalOverlay"
              Panel.ZIndex="40"
              MouseDown="VideoListModalOverlayMouseDown"
              Visibility="{Binding IsModalOpen, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
            <Border Width="420"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{DynamicResource SurfaceStrokeColorFlyoutBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Win11ControlCornerRadius}"
                    Visibility="{Binding IsSplitPanelOpen, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                <ui:Grid RowDefinitions="Auto,Auto,Auto">
                    <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                        <ui:FontIcon Grid.Column="0"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                     FontSize="20"
                                     Glyph="{x:Static ui:FontSymbols.Cut}" />
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="分割视频" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding SplitTargetFileName}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Grid>

                    <ui:Grid Grid.Row="1"
                             Margin="0,18,0,0"
                             ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="分割间隔" />
                        <ui:TextBox Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Text="{Binding SplitDurationValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox Grid.Column="2"
                                  Width="92"
                                  Margin="8,0,0,0"
                                  SelectedIndex="{Binding SplitDurationUnitIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="分钟" />
                            <ComboBoxItem Content="秒" />
                            <ComboBoxItem Content="小时" />
                        </ComboBox>
                    </ui:Grid>

                    <ui:Grid Grid.Row="2"
                             Margin="0,18,0,0"
                             ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding OperationProgressText}"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1"
                                Margin="0,0,8,0"
                                Command="{Binding CloseModalCommand}"
                                Content="取消"
                                IsEnabled="{Binding IsIdle}" />
                        <Button Grid.Column="2"
                                Command="{Binding ConfirmSplitCommand}"
                                Content="开始"
                                IsEnabled="{Binding IsIdle}" />
                    </ui:Grid>
                </ui:Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
