<UserControl x:Class="Emerde.Views.ScreenRecordListWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
                 xmlns:local="clr-namespace:Emerde.Views"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
                 FontSize="14"
                 mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="VideoListToolbarButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="VideoListIconButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="VideoMetaChipStyle" TargetType="{x:Type Border}">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="CornerRadius" Value="{StaticResource Win11ControlCornerRadius}" />
            <Setter Property="Background" Value="#18337DFF" />
            <Setter Property="BorderBrush" Value="#30337DFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="VideoMetaChipTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="VideoListDialogContent">
        <Grid x:Name="VideoListContentRoot" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="84" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <TextBlock Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="{I18N VideoListTitle}" />
                        <Button Command="{Binding RefreshCommand}"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding IsIdle}"
                                Style="{StaticResource VideoListToolbarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Margin="0,0,7,0"
                                             Glyph="{x:Static ui:FontSymbols.Sync}" />
                                <TextBlock Text="{I18N RefreshButton}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ImportFolderCommand}"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding IsIdle}"
                                Style="{StaticResource VideoListToolbarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Margin="0,0,7,0"
                                             Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                                <TextBlock Text="{I18N ImportFolder}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenSaveFolderCommand}"
                                Style="{StaticResource VideoListToolbarButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Margin="0,0,7,0"
                                             Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                                <TextBlock Text="{I18N SaveFolder}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <Button Command="{Binding BeginMultiSelectCommand}"
                                Content="{I18N MultiSelect}">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource VideoListToolbarButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="{x:Type StackPanel}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding SelectedVideoSummary}" />
                            <Button Margin="0,0,8,0"
                                    Command="{Binding SelectAllCommand}"
                                    Style="{StaticResource VideoListIconButtonStyle}"
                                    ToolTip="全选">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Glyph="{x:Static ui:FontSymbols.Accept}" />
                            </Button>
                            <Button Margin="0,0,8,0"
                                    Command="{Binding InvertSelectionCommand}"
                                    Style="{StaticResource VideoListIconButtonStyle}"
                                    ToolTip="反选">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Glyph="{x:Static ui:FontSymbols.Switch}" />
                            </Button>
                            <Button Command="{Binding CancelMultiSelectCommand}"
                                    Style="{StaticResource VideoListIconButtonStyle}"
                                    ToolTip="取消选择（Esc）">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                             Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Command="{Binding ToggleSortCommand}"
                            Margin="0,0,8,0"
                            IsEnabled="{Binding IsIdle}"
                            Style="{StaticResource VideoListToolbarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Margin="0,0,7,0"
                                         FontFamily="{DynamicResource SymbolThemeFontFamily}">
                                <ui:FontIcon.Style>
                                    <Style TargetType="{x:Type ui:FontIcon}">
                                        <Setter Property="Glyph" Value="{x:Static ui:FontSymbols.ChevronUp}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSortDescending}" Value="True">
                                                <Setter Property="Glyph" Value="{x:Static ui:FontSymbols.ChevronDown}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:FontIcon.Style>
                            </ui:FontIcon>
                            <TextBlock Text="{Binding SortDirectionText}" />
                        </StackPanel>
                    </Button>
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{I18N StreamerLabel}" />
                    <ComboBox Width="150"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding StreamerOptions}"
                              SelectedItem="{Binding SelectedStreamer, Mode=TwoWay}" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{I18N TimeRangeLabel}" />
                    <ComboBox Width="130"
                              ItemsSource="{Binding TimeRangeOptions}"
                              SelectedIndex="{Binding SelectedTimeRangeIndex, Mode=TwoWay}" />
                </StackPanel>
            </Grid>

            <Grid x:Name="VideoSelectionHost"
                  Grid.Row="1"
                  ClipToBounds="True"
                  PreviewMouseLeftButtonDown="VideoSelectionHostPreviewMouseLeftButtonDown"
                  PreviewMouseLeftButtonUp="VideoSelectionHostPreviewMouseLeftButtonUp"
                  PreviewMouseMove="VideoSelectionHostPreviewMouseMove"
                  PreviewMouseRightButtonDown="VideoSelectionHostPreviewMouseRightButtonDown"
                  LostMouseCapture="VideoSelectionHostLostMouseCapture">
                <ListBox x:Name="VideoListBox"
                         ItemsSource="{Binding Videos}"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectedItem="{Binding RegularSelectedItem, Mode=TwoWay}"
                         SelectionMode="Single"
                         ScrollViewer.CanContentScroll="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.ScrollChanged="VideoListScrollChanged"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="VideoCardShell"
                                Margin="2,8,10,0"
                                Padding="12"
                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                 BorderThickness="1"
                                 CornerRadius="{StaticResource Win11ControlCornerRadius}"
                                 Loaded="VideoCardLoaded">
                            <Border.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="打开视频"
                                              Command="{Binding Tag.OpenVideoCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <MenuItem Header="打开目录"
                                              Command="{Binding Tag.OpenDirectoryCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <MenuItem Header="重命名"
                                              Command="{Binding Tag.RenameVideoCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <MenuItem Header="转码"
                                              Command="{Binding Tag.TranscodeVideoCommand}"
                                              CommandParameter="{Binding DataContext}"
                                              IsEnabled="{Binding DataContext.CanTranscode}" />
                                    <Separator />
                                    <MenuItem Header="合并"
                                              Command="{Binding Tag.OpenMergeSelectedCommand}"
                                              IsEnabled="{Binding Tag.CanMergeSelectedVideos}" />
                                    <MenuItem Header="分割"
                                              Command="{Binding Tag.SplitContextCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <MenuItem Header="移动"
                                              Command="{Binding Tag.MoveContextCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <MenuItem Header="复制"
                                              Command="{Binding Tag.CopyContextCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                    <MenuItem Header="删除"
                                              Command="{Binding Tag.DeleteContextCommand}"
                                              CommandParameter="{Binding DataContext}" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="146" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="128"
                                        Height="72"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="#16000000"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Win11ControlCornerRadius}"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Border CornerRadius="{StaticResource Win11ControlCornerRadius}">
                                            <Border.Background>
                                                <ImageBrush AlignmentX="Center"
                                                            AlignmentY="Center"
                                                            ImageSource="{Binding ThumbnailPath, Converter={x:Static local:ThumbnailImageConverter.Instance}}"
                                                            Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <ui:FontIcon HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                     FontSize="24"
                                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                     Glyph="{x:Static ui:FontSymbols.Video}">
                                            <ui:FontIcon.Style>
                                                <Style TargetType="{x:Type ui:FontIcon}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:FontIcon.Style>
                                        </ui:FontIcon>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="0,0,20,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding FileName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Margin="0,10,0,0"
                                                Orientation="Horizontal">
                                        <Border MaxWidth="220" Style="{StaticResource VideoMetaChipStyle}">
                                            <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                       Text="{Binding StreamerChipText}" />
                                        </Border>
                                        <Border MaxWidth="160" Style="{StaticResource VideoMetaChipStyle}">
                                            <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                       Text="{Binding ResolutionChipText}" />
                                        </Border>
                                        <Border MaxWidth="150" Style="{StaticResource VideoMetaChipStyle}">
                                            <TextBlock Style="{StaticResource VideoMetaChipTextStyle}"
                                                       Text="{Binding BitrateChipText}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="{x:Type StackPanel}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsMultiSelectMode, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding DataContext.OpenVideoCommand, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="{I18N OpenVideo}" />
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding DataContext.TranscodeVideoCommand, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="{I18N TranscodeVideo}">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanTranscode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding DataContext.SplitVideoCommand, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="{I18N SplitButton}" />
                                    <Button Command="{Binding DataContext.OpenDirectoryCommand, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}"
                                            CommandParameter="{Binding}"
                                            Content="{I18N OpenFolder}" />
                                </StackPanel>

                                <CheckBox Grid.Column="3"
                                          Width="22"
                                          Height="22"
                                          MinWidth="22"
                                          Margin="12,0,0,0"
                                          Padding="0"
                                          HorizontalAlignment="Right"
                                          HorizontalContentAlignment="Center"
                                          VerticalAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          PreviewMouseLeftButtonDown="SelectionCheckBoxPreviewMouseLeftButtonDown"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                    <CheckBox.Style>
                                        <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource {x:Type CheckBox}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsMultiSelectMode, RelativeSource={RelativeSource AncestorType={x:Type local:ScreenRecordListWindow}}}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                <Setter TargetName="VideoCardShell" Property="Background" Value="#18337DFF" />
                                <Setter TargetName="VideoCardShell" Property="BorderBrush" Value="#60337DFF" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="VideoCardShell" Property="Background" Value="#2A4DA7B0" />
                                <Setter TargetName="VideoCardShell" Property="BorderBrush" Value="#884DA7B0" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                </ListBox>
                <Canvas Panel.ZIndex="30" IsHitTestVisible="False">
                    <Rectangle x:Name="VideoSelectionRectangle"
                               Fill="#2A4DA7B0"
                               StrokeThickness="0"
                               Visibility="Collapsed" />
                </Canvas>
                <Border Height="6"
                        VerticalAlignment="Top"
                        Panel.ZIndex="20"
                        Background="{DynamicResource EmerdeSurfaceBrush}"
                        IsHitTestVisible="False"
                        OpacityMask="{StaticResource TopEdgeFadeOpacityMask}" />
                <Border Height="6"
                        VerticalAlignment="Bottom"
                        Panel.ZIndex="20"
                        Background="{DynamicResource EmerdeSurfaceBrush}"
                        IsHitTestVisible="False"
                        OpacityMask="{StaticResource BottomEdgeFadeOpacityMask}" />
            </Grid>
        </Grid>

        <Grid x:Name="VideoListDialogOverlay"
              Background="Transparent"
              IsHitTestVisible="False"
              Panel.ZIndex="35"
              Visibility="Collapsed" />

        <Grid x:Name="VideoListModalOverlay"
              Panel.ZIndex="40"
              MouseDown="VideoListModalOverlayMouseDown"
              Visibility="{Binding IsModalOpen, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
            <Border Width="420"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{DynamicResource SurfaceStrokeColorFlyoutBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Win11ControlCornerRadius}"
                    Visibility="{Binding IsSplitPanelOpen, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                <ui:Grid RowDefinitions="Auto,Auto,Auto">
                    <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                        <ui:FontIcon Grid.Column="0"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                     FontSize="20"
                                     Glyph="{x:Static ui:FontSymbols.Cut}" />
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{I18N SplitVideo}" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding SplitTargetFileName}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </ui:Grid>

                    <ui:Grid Grid.Row="1"
                             Margin="0,18,0,0"
                             ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="{I18N SplitInterval}" />
                        <ui:TextBox Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Text="{Binding SplitDurationValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox Grid.Column="2"
                                  Width="92"
                                  Margin="8,0,0,0"
                                  SelectedIndex="{Binding SplitDurationUnitIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="{I18N Minutes}" />
                            <ComboBoxItem Content="{I18N Seconds}" />
                            <ComboBoxItem Content="{I18N Hours}" />
                        </ComboBox>
                    </ui:Grid>

                    <ui:Grid Grid.Row="2"
                             Margin="0,18,0,0"
                             ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding OperationProgressText}"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1"
                                Margin="0,0,8,0"
                                Command="{Binding CloseModalCommand}"
                                Content="{I18N ButtonOfCancel}"
                                IsEnabled="{Binding IsIdle}" />
                        <Button Grid.Column="2"
                                Command="{Binding ConfirmSplitCommand}"
                                Content="{I18N StartButton}"
                                IsEnabled="{Binding IsIdle}" />
                    </ui:Grid>
                </ui:Grid>
            </Border>
            <Border Width="460"
                    Padding="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{DynamicResource SurfaceStrokeColorFlyoutBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Win11ControlCornerRadius}"
                    Visibility="{Binding IsMergePanelOpen, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                <ui:Grid RowDefinitions="Auto,Auto,Auto,Auto">
                    <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                        <ui:FontIcon Grid.Column="0"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                     FontSize="20"
                                     Glyph="{x:Static ui:FontSymbols.Link}" />
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="{I18N MergeVideos}" />
                    </ui:Grid>
                    <TextBlock Grid.Row="1"
                               Margin="0,16,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding MergeWarningText}"
                               TextWrapping="Wrap" />
                    <ProgressBar Grid.Row="2"
                                 Height="6"
                                 Margin="0,16,0,0"
                                 IsIndeterminate="{Binding IsMergeProgressIndeterminate}"
                                 Maximum="100"
                                 Value="{Binding MergeProgressValue}" />
                    <ui:Grid Grid.Row="3"
                             Margin="0,18,0,0"
                             ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding OperationProgressText}"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1"
                                Margin="0,0,8,0"
                                Command="{Binding CloseModalCommand}"
                                Content="{I18N ButtonOfCancel}"
                                IsEnabled="{Binding IsIdle}" />
                        <Button Grid.Column="2"
                                Command="{Binding ConfirmMergeSelectedCommand}"
                                Content="{I18N StartButton}"
                                IsEnabled="{Binding IsIdle}" />
                    </ui:Grid>
                </ui:Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
