<UserControl x:Class="Emerde.Views.LivePreviewPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta">
    <UserControl.Resources>
        <Style x:Key="PreviewControlButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#2EFFFFFF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="ButtonChrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#42FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#55FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border x:Name="PanelChrome"
            Padding="12"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ui:StackPanel x:Name="RoomHeader"
                           Grid.Row="0"
                           Orientation="Horizontal"
                           Spacing="10">
                <vio:PersonPicture Width="42"
                                   Height="42"
                                   ProfilePicture="{Binding SelectedItem.AvatarThumbUrl}"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="True" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedItem.NickName}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="12"
                               Opacity="0.65"
                               Text="{Binding SelectedItem.StreamStatusText}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </ui:StackPanel>

            <Grid x:Name="PreviewHeader"
                  Grid.Row="1"
                  Margin="0,12,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="12"
                               Opacity="0.65"
                               Text="{I18N LivePreview}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Bottom"
                           FontSize="12"
                           Opacity="0.65"
                           Text="{Binding SelectedItem.PreviewSourceText}" />
            </Grid>

            <Grid x:Name="PreviewViewport"
                  Grid.Row="2"
                  MinHeight="180"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  MouseEnter="PreviewViewport_OnMouseActivity"
                  MouseMove="PreviewViewport_OnMouseActivity">
                <Grid x:Name="VideoSurface"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="Black">
                    <vlc:VideoView MediaPlayer="{Binding LivePreviewMediaPlayer}" />
                </Grid>
                <ui:StackPanel HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.72"
                               Spacing="8"
                               Visibility="{Binding IsPreviewIdle, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                    <ui:FontIcon HorizontalAlignment="Center"
                                 FontSize="36"
                                 Foreground="White"
                                 Glyph="{x:Static ui:FontSymbols.Video}" />
                    <TextBlock FontSize="12"
                               Foreground="White"
                               Text="{Binding LivePreviewStatusText}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </ui:StackPanel>
                <Popup x:Name="PreviewControlsPopup"
                       AllowsTransparency="True"
                       DataContext="{Binding DataContext, ElementName=Root}"
                       Placement="AbsolutePoint"
                       PopupAnimation="Fade"
                       StaysOpen="True">
                    <Border x:Name="PreviewControls"
                            Padding="6"
                            Background="#B8000000"
                            CornerRadius="5"
                            MouseEnter="PreviewControls_OnMouseEnter"
                            MouseLeave="PreviewControls_OnMouseLeave">
                    <ui:StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Style="{StaticResource PreviewControlButtonStyle}"
                                Command="{Binding TogglePreviewPauseCommand}"
                                IsEnabled="{Binding SelectedItem.CanPreview}">
                            <ContentControl>
                                <c:If Condition="{Binding IsPreviewPlaying}">
                                    <c:If.TrueValue>
                                        <Viewbox Width="14" Height="14" Stretch="Uniform">
                                            <Canvas Width="24" Height="24">
                                                <Rectangle Canvas.Left="7" Canvas.Top="5" Width="4" Height="14" Fill="White" RadiusX="1" RadiusY="1" />
                                                <Rectangle Canvas.Left="13" Canvas.Top="5" Width="4" Height="14" Fill="White" RadiusX="1" RadiusY="1" />
                                            </Canvas>
                                        </Viewbox>
                                    </c:If.TrueValue>
                                    <c:If.FalseValue>
                                        <Viewbox Width="14" Height="14" Stretch="Uniform">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M8,5 L19,12 L8,19 Z" Fill="White" />
                                            </Canvas>
                                        </Viewbox>
                                    </c:If.FalseValue>
                                </c:If>
                            </ContentControl>
                        </Button>
                        <Button Style="{StaticResource PreviewControlButtonStyle}"
                                Command="{Binding TogglePreviewMuteCommand}">
                            <ContentControl>
                                <c:If Condition="{Binding IsPreviewMuted}">
                                    <c:If.TrueValue>
                                        <Viewbox Width="16" Height="16" Stretch="Uniform">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M4,9 L8,9 L13,5 L13,19 L8,15 L4,15 Z" Fill="White" />
                                                <Path Data="M17,9 L21,13 M21,9 L17,13" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </c:If.TrueValue>
                                    <c:If.FalseValue>
                                        <Viewbox Width="16" Height="16" Stretch="Uniform">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M4,9 L8,9 L13,5 L13,19 L8,15 L4,15 Z" Fill="White" />
                                                <Path Data="M16,8 C18,10 18,14 16,16 M18,5 C22,9 22,15 18,19" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" />
                                            </Canvas>
                                        </Viewbox>
                                    </c:If.FalseValue>
                                </c:If>
                            </ContentControl>
                        </Button>
                        <Button Style="{StaticResource PreviewControlButtonStyle}"
                                Click="ToggleWindowSize_OnClick">
                            <Grid>
                                <Viewbox x:Name="MaximizeIcon" Width="16" Height="16" Stretch="Uniform">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M5,10 L5,5 L10,5 M14,5 L19,5 L19,10 M19,14 L19,19 L14,19 M10,19 L5,19 L5,14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" />
                                    </Canvas>
                                </Viewbox>
                                <Viewbox x:Name="RestoreIcon" Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M8,4 L20,4 L20,16 M4,8 L16,8 L16,20 L4,20 Z" Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" Fill="Transparent" />
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource PreviewControlButtonStyle}"
                                Command="{Binding GotoRoomUrlCommand}">
                            <Viewbox Width="16" Height="16" Stretch="Uniform">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M5,6 L5,19 L18,19 L18,14 M12,5 L19,5 L19,12 M11,13 L19,5" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </ui:StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Grid>
    </Border>
</UserControl>
