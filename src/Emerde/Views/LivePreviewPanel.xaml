<UserControl x:Class="Emerde.Views.LivePreviewPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="PreviewControlButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="ButtonChrome"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Win11ControlCornerRadius}"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#28FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#55FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border x:Name="PanelChrome"
            Padding="0"
            Background="{DynamicResource EmerdePanelBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="{StaticResource Win11ControlCornerRadius}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid x:Name="PreviewViewport"
                  Grid.Row="0"
                  MinHeight="180"
                  Background="Transparent"
                  ClipToBounds="True">
                <Grid x:Name="VideoSurface"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Background="Transparent">
                    <Grid x:Name="PreviewOverlayRoot"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Visibility="Collapsed">
                        <Border x:Name="PreviewTouchLayer"
                                Panel.ZIndex="0"
                                Background="#01000000"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                MouseEnter="PreviewViewport_OnMouseActivity"
                                MouseMove="PreviewViewport_OnMouseActivity" />
                        <Border x:Name="PreviewControls"
                                Panel.ZIndex="1"
                                Margin="12"
                                Padding="8,6"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="#D0111111"
                                CornerRadius="{StaticResource Win11ControlCornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0"
                                MouseEnter="PreviewControls_OnMouseEnter"
                                MouseLeave="PreviewControls_OnMouseLeave">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Style="{StaticResource PreviewControlButtonStyle}"
                                        Command="{Binding TogglePreviewPauseCommand}"
                                        IsEnabled="{Binding PreviewingRoom.CanPreview}"
                                        ToolTip="{Binding PreviewPlaybackToolTip}">
                                    <ContentControl>
                                        <c:If Condition="{Binding IsPreviewPlaying}">
                                            <c:If.TrueValue>
                                                <Viewbox Width="14" Height="14" Stretch="Uniform">
                                                    <Canvas Width="24" Height="24">
                                                        <Rectangle Canvas.Left="7" Canvas.Top="5" Width="4" Height="14" Fill="White" RadiusX="0" RadiusY="0" />
                                                        <Rectangle Canvas.Left="13" Canvas.Top="5" Width="4" Height="14" Fill="White" RadiusX="0" RadiusY="0" />
                                                    </Canvas>
                                                </Viewbox>
                                            </c:If.TrueValue>
                                            <c:If.FalseValue>
                                                <Viewbox Width="14" Height="14" Stretch="Uniform">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M8,5 L19,12 L8,19 Z" Fill="White" />
                                                    </Canvas>
                                                </Viewbox>
                                            </c:If.FalseValue>
                                        </c:If>
                                    </ContentControl>
                                </Button>
                                <Button Grid.Column="1"
                                        Margin="4,0,0,0"
                                        Style="{StaticResource PreviewControlButtonStyle}"
                                        Command="{Binding TogglePreviewMuteCommand}"
                                        ToolTip="{Binding PreviewMuteToolTip}">
                                    <ContentControl>
                                        <c:If Condition="{Binding IsPreviewMuted}">
                                            <c:If.TrueValue>
                                                <Viewbox Width="16" Height="16" Stretch="Uniform">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M4,9 L8,9 L13,5 L13,19 L8,15 L4,15 Z" Fill="White" />
                                                        <Path Data="M17,9 L21,13 M21,9 L17,13" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    </Canvas>
                                                </Viewbox>
                                            </c:If.TrueValue>
                                            <c:If.FalseValue>
                                                <Viewbox Width="16" Height="16" Stretch="Uniform">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Data="M4,9 L8,9 L13,5 L13,19 L8,15 L4,15 Z" Fill="White" />
                                                        <Path Data="M16,8 C18,10 18,14 16,16 M18,5 C22,9 22,15 18,19" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" />
                                                    </Canvas>
                                                </Viewbox>
                                            </c:If.FalseValue>
                                        </c:If>
                                    </ContentControl>
                                </Button>
                                <ui:StackPanel Grid.Column="2"
                                               Margin="12,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Orientation="Horizontal"
                                               Spacing="7">
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="White"
                                               Text="{Binding LivePreviewStatusText}" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="#AFFFFFFF"
                                               Text="·" />
                                    <TextBlock MaxWidth="180"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="#AFFFFFFF"
                                               Text="{Binding PreviewingRoom.PreviewSourceText, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis" />
                                </ui:StackPanel>
                                <Button x:Name="WindowSizeButton"
                                        Grid.Column="3"
                                        Style="{StaticResource PreviewControlButtonStyle}"
                                        Click="ToggleWindowSize_OnClick">
                                    <Grid>
                                        <Viewbox x:Name="MaximizeIcon" Width="16" Height="16" Stretch="Uniform">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M5,10 L5,5 L10,5 M14,5 L19,5 L19,10 M19,14 L19,19 L14,19 M10,19 L5,19 L5,14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" />
                                            </Canvas>
                                        </Viewbox>
                                        <Viewbox x:Name="RestoreIcon" Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M8,4 L20,4 L20,16 M4,8 L16,8 L16,20 L4,20 Z" Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" Fill="Transparent" />
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
