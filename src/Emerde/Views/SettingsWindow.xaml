<UserControl x:Class="Emerde.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:b="http://schemas.github.com/computedbehaviors/2024/xaml"
                 xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
                 xmlns:controls="clr-namespace:Emerde.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:local="clr-namespace:Emerde.Views"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
                   FontSize="14"
                   mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="{x:Type ui:Card}" BasedOn="{StaticResource {x:Type ui:Card}}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{DynamicResource EmerdePanelBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="86" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:Card}">
                        <Border MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource Win11ControlCornerRadius}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ui:CardExpander}" BasedOn="{StaticResource {x:Type ui:CardExpander}}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{DynamicResource EmerdePanelBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="86" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="ContentPadding" Value="0,8,0,14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ui:CardExpander}">
                        <Border x:Name="RootBorder"
                                MinHeight="{TemplateBinding MinHeight}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClipToBounds="True"
                                CornerRadius="{StaticResource Win11ControlCornerRadius}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border x:Name="HeaderChrome"
                                        Grid.Row="0"
                                        Padding="{TemplateBinding Padding}"
                                        Background="Transparent"
                                        CornerRadius="{StaticResource Win11ControlCornerRadius}">
                                    <Grid MinHeight="54">
                                        <ContentPresenter Margin="0,0,36,0"
                                                          VerticalAlignment="Center"
                                                          ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        <Path x:Name="ChevronPath"
                                              Width="9"
                                              Height="6"
                                              Margin="0,0,10,0"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Data="M 0 6 L 4.5 1 L 9 6"
                                              Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                              RenderTransformOrigin="0.5,0.5"
                                              Stretch="Fill">
                                            <Path.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                </Border>
                                <Border x:Name="ExpandSite"
                                        Grid.Row="1"
                                        MaxHeight="0"
                                        Padding="{TemplateBinding ContentPadding}"
                                        ClipToBounds="True"
                                        Opacity="0"
                                        Visibility="Collapsed">
                                    <ContentPresenter ContentSource="Content"
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="MaxHeight" Value="1600" />
                                <Setter TargetName="ExpandSite" Property="Opacity" Value="1" />
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="HeaderChrome" Property="CornerRadius" Value="8,8,0,0" />
                                <Setter TargetName="ChevronPath" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderChrome" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid x:Name="SettingsDialogContent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Margin="0,0,0,16"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Text="{I18N Settings}" />
        <ui:Grid x:Name="SettingsContentRoot" Grid.Row="1" Margin="0">
            <ScrollViewer x:Name="SettingsScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="None"
                          VerticalScrollBarVisibility="Visible">
                <ui:StackPanel x:Name="SettingsStackPanel"
                               Margin="20,10,22,18"
                               HorizontalAlignment="Stretch"
                               Spacing="8">
                    <TextBlock Margin="4,0,0,4"
                               FontSize="14"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                               Text="{I18N AppearanceSettings}" />
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.LocaleLanguage}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="{I18N Language}" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="{I18N LanguageHint}" />
                            </ui:Grid>
                            <ComboBox Grid.Column="2"
                                      MinWidth="150"
                                      Margin="0,0,28,0"
                                      SelectedIndex="{Binding LanguageIndex}">
                                <ComboBoxItem Content="{I18N TrackingSystem}" />
                                <ComboBoxItem Content="简体中文" />
                                <ComboBoxItem Content="繁體中文" />
                                <ComboBoxItem Content="English" />
                                <ComboBoxItem Content="日本語" />
                            </ComboBox>
                        </ui:Grid>
                    </ui:Card>
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.Color}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="{I18N ThemeColor}" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="{I18N ThemeColorHint}" />
                            </ui:Grid>
                            <ComboBox Grid.Column="2"
                                      MinWidth="150"
                                      Margin="0,0,28,0"
                                      SelectedIndex="{Binding ThemeIndex}">
                                <ComboBoxItem Content="{I18N TrackingSystem}" />
                                <ComboBoxItem Content="{I18N ThemeOfDarkMode}" />
                                <ComboBoxItem Content="{I18N ThemeOfLightMode}" />
                            </ComboBox>
                        </ui:Grid>
                    </ui:Card>
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.DeviceMonitorRightPic}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="{I18N TrayStatus}" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="{I18N TrayStatusHint}" />
                            </ui:Grid>
                            <ui:ToggleSwitch Grid.Column="2"
                                             Margin="0,0,28,0"
                                             IsChecked="{Binding IsUseStatusTray, Mode=TwoWay}" />
                        </ui:Grid>
                    </ui:Card>
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.AppIconDefault}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="{I18N CreateDesktopShortcut}" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="{I18N CreateDesktopShortcutHint}" />
                            </ui:Grid>
                            <Button Grid.Column="2"
                                    Margin="0,0,28,0"
                                    Command="{Binding CreateDesktopShortcutCommand}"
                                    Content="{I18N ButtonOfCreateNow}" />
                        </ui:Grid>
                    </ui:Card>
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.Document}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="运行日志" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="{Binding SessionLogStatus}" />
                            </ui:Grid>
                            <ui:StackPanel Grid.Column="2"
                                           Margin="0,0,28,0"
                                           Orientation="Horizontal"
                                           Spacing="8">
                                <Button Command="{Binding OpenLogFolderCommand}" Content="打开目录" />
                                <Button Command="{Binding ExportLogsCommand}" Content="导出" />
                                <ui:ToggleSwitch IsChecked="{Binding IsSessionLogEnabled, Mode=TwoWay}" />
                            </ui:StackPanel>
                        </ui:Grid>
                    </ui:Card>
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.Document}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="配置文件" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="{Binding ConfigFilePath}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ConfigFilePath}" />
                            </ui:Grid>
                            <ui:StackPanel Grid.Column="2"
                                           Margin="0,0,28,0"
                                           Orientation="Horizontal"
                                           Spacing="8">
                                <Button Command="{Binding OpenConfigFolderCommand}" Content="打开位置" />
                                <Button Command="{Binding ImportConfigCommand}" Content="导入" />
                                <Button Command="{Binding ExportConfigCommand}" Content="导出" />
                                <Button Command="{Binding ResetConfigCommand}" Content="重置" />
                            </ui:StackPanel>
                        </ui:Grid>
                    </ui:Card>
                    <TextBlock Margin="4,0,0,4"
                               FontSize="14"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                               Text="{I18N RecordSettings}" />
                    <ui:CardExpander>
                        <ui:CardExpander.Header>
                            <ui:Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock MinWidth="26"
                                               Margin="4,0,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource SymbolThemeFontFamily}"
                                               FontSize="18"
                                               Text="{x:Static ui:FontSymbols.Ringer}" />
                                </Grid>
                                <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Text="{I18N LiveNotification}" />
                                    <TextBlock Grid.Row="1"
                                               FontSize="11"
                                               Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                               Text="{I18N LiveNotificationHint}" />
                                </ui:Grid>
                                <Grid Grid.Column="2" Margin="0,0,12,0">
                                    <ui:ToggleSwitch IsChecked="{Binding IsToNotify, Mode=TwoWay}" />
                                </Grid>
                            </ui:Grid>
                        </ui:CardExpander.Header>
                        <ui:StackPanel Spacing="8">
                            <ui:StackPanel Margin="42,0,28,0"
                                           IsEnabled="{Binding IsToNotify}"
                                           Spacing="12">
                                <CheckBox Content="{I18N LiveNotificationToSystem}" IsChecked="{Binding IsToNotifyWithSystem, Mode=TwoWay}" />
                                <ui:Grid ColumnDefinitions="Auto,*">
                                    <CheckBox Grid.Column="0"
                                              Content="{I18N LiveNotificationToPlayMusic}"
                                              IsChecked="{Binding IsToNotifyWithMusic, Mode=TwoWay}" />
                                    <ui:TextBox Grid.Column="1"
                                                Margin="8,0,0,0"
                                                PlaceholderText="{I18N LiveNotificationToPlayMusicPath}"
                                                Text="{Binding ToNotifyWithMusicPath, Mode=TwoWay}" />
                                </ui:Grid>
                                <ui:Grid ColumnDefinitions="Auto,*">
                                    <CheckBox Grid.Column="0"
                                              Content="{I18N LiveNotificationToMail}"
                                              IsChecked="{Binding IsToNotifyWithEmail, Mode=TwoWay}" />
                                    <ui:Grid Grid.Column="1" ColumnDefinitions="*,*,*">
                                        <ui:TextBox Grid.Column="0"
                                                    Margin="8,0,0,0"
                                                    PlaceholderText="SMTP"
                                                    Text="{Binding ToNotifyWithEmailSmtp, Mode=TwoWay}" />
                                        <ui:TextBox Grid.Column="1"
                                                    Margin="8,0,0,0"
                                                    PlaceholderText="{I18N Account}"
                                                    Text="{Binding ToNotifyWithEmailUserName, Mode=TwoWay}" />
                                        <ui:TextBox Grid.Column="2"
                                                    Margin="8,0,0,0"
                                                    PlaceholderText="{I18N Password}"
                                                    Text="{Binding ToNotifyWithEmailPassword, Mode=TwoWay}" />
                                    </ui:Grid>
                                </ui:Grid>
                                <ui:Grid ColumnDefinitions="Auto,*">
                                    <CheckBox Grid.Column="0"
                                              Content="{I18N LiveNotificationToGotoLiveRoom}"
                                              IsChecked="{Binding IsToNotifyGotoRoomUrl, Mode=TwoWay}" />
                                    <ui:ToggleSwitch Grid.Column="1"
                                                     Margin="8,0,0,0"
                                                     Content="{I18N LiveNotificationToGotoLiveRoomAndMute}"
                                                     IsChecked="{Binding IsToNotifyGotoRoomUrlAndMute, Mode=TwoWay}" />
                                </ui:Grid>
                            </ui:StackPanel>
                        </ui:StackPanel>
                    </ui:CardExpander>
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.Video}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="{I18N EnableRecord}" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="{I18N EnableRecordHint}" />
                            </ui:Grid>
                            <ui:ToggleSwitch Grid.Column="2"
                                             Margin="0,0,28,0"
                                             IsChecked="{Binding IsToRecord, Mode=TwoWay}" />
                        </ui:Grid>
                    </ui:Card>
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.Radar}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="自动监控" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="控制跟随全局设置的房间是否自动检查直播状态。" />
                            </ui:Grid>
                            <ui:ToggleSwitch Grid.Column="2"
                                             Margin="0,0,28,0"
                                             IsChecked="{Binding IsToMonitor, Mode=TwoWay}" />
                        </ui:Grid>
                    </ui:Card>
                    <ui:Card>
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.DeviceMonitorRightPic}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="{I18N RoutineInterval}" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="{I18N RoutineIntervalHint}" />
                            </ui:Grid>
                            <ui:StackPanel Grid.Column="2"
                                           Margin="0,0,28,0"
                                           Orientation="Horizontal"
                                           Spacing="8">
                                <controls:CompactNumberBox MinWidth="112"
                                                           Maximum="{c:DoubleMaxValue}"
                                                           Minimum="1"
                                                           Value="{Binding RoutineInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox MinWidth="86"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding TimeUnitOptions}"
                                          SelectedValue="{Binding RoutineIntervalUnitIndex, Mode=TwoWay}"
                                          SelectedValuePath="Value" />
                            </ui:StackPanel>
                        </ui:Grid>
                    </ui:Card>
                    <ui:Card Visibility="{Binding IsRoutineSchedulePreset, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                        <ui:Grid MinHeight="35" ColumnDefinitions="Auto,*,Auto">
                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock MinWidth="26"
                                           Margin="4,0,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                           FontSize="18"
                                           Text="{x:Static ui:FontSymbols.Recent}" />
                            </Grid>
                            <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Text="监控计划" />
                                <TextBlock Grid.Row="1"
                                           FontSize="11"
                                           Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                           Text="按星期和时间段限制全局自动监控。" />
                            </ui:Grid>
                            <ComboBox Grid.Column="2"
                                      MinWidth="150"
                                      Margin="0,0,28,0"
                                      SelectedIndex="{Binding RoutineScheduleModeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="始终运行" ToolTip="周一至周日，全天运行" />
                                <ComboBoxItem Content="工作日运行" ToolTip="周一至周五运行" />
                                <ComboBoxItem Content="周末运行" ToolTip="周六、周日运行" />
                                <ComboBoxItem Content="夜间运行" ToolTip="每天 18:00 至次日 08:00 运行" />
                                <ComboBoxItem Content="自定义计划" ToolTip="手动选择星期和起止时间段" />
                            </ComboBox>
                        </ui:Grid>
                    </ui:Card>
                    <ui:CardExpander IsExpanded="True"
                                     Visibility="{Binding IsRoutineScheduleCustom, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                        <ui:CardExpander.Header>
                            <ui:Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock MinWidth="26"
                                               Margin="4,0,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                               FontSize="18"
                                               Text="{x:Static ui:FontSymbols.Recent}" />
                                </Grid>
                                <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Text="监控计划" />
                                    <TextBlock Grid.Row="1"
                                               FontSize="11"
                                               Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                               Text="按星期和时间段限制全局自动监控。" />
                                </ui:Grid>
                                <ComboBox Grid.Column="2"
                                          MinWidth="150"
                                          Margin="0,0,12,0"
                                          SelectedIndex="{Binding RoutineScheduleModeIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="始终运行" ToolTip="周一至周日，全天运行" />
                                    <ComboBoxItem Content="工作日运行" ToolTip="周一至周五运行" />
                                    <ComboBoxItem Content="周末运行" ToolTip="周六、周日运行" />
                                    <ComboBoxItem Content="夜间运行" ToolTip="每天 18:00 至次日 08:00 运行" />
                                    <ComboBoxItem Content="自定义计划" ToolTip="手动选择星期和起止时间段" />
                                </ComboBox>
                            </ui:Grid>
                        </ui:CardExpander.Header>
                        <ui:StackPanel Margin="42,0,28,0"
                                       Spacing="12"
                                       Visibility="{Binding IsRoutineScheduleCustom, Converter={x:Static c:BoolToVisibilityConverter.Instance}}">
                            <WrapPanel>
                                <ToggleButton Margin="0,0,8,8" Content="周一" IsChecked="{Binding RoutineScheduleMonday, Mode=TwoWay}" />
                                <ToggleButton Margin="0,0,8,8" Content="周二" IsChecked="{Binding RoutineScheduleTuesday, Mode=TwoWay}" />
                                <ToggleButton Margin="0,0,8,8" Content="周三" IsChecked="{Binding RoutineScheduleWednesday, Mode=TwoWay}" />
                                <ToggleButton Margin="0,0,8,8" Content="周四" IsChecked="{Binding RoutineScheduleThursday, Mode=TwoWay}" />
                                <ToggleButton Margin="0,0,8,8" Content="周五" IsChecked="{Binding RoutineScheduleFriday, Mode=TwoWay}" />
                                <ToggleButton Margin="0,0,8,8" Content="周六" IsChecked="{Binding RoutineScheduleSaturday, Mode=TwoWay}" />
                                <ToggleButton Margin="0,0,8,8" Content="周日" IsChecked="{Binding RoutineScheduleSunday, Mode=TwoWay}" />
                            </WrapPanel>
                            <ui:Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="时间段" />
                                <controls:CompactNumberBox Grid.Column="1"
                                                           Width="72"
                                                           Margin="12,0,0,0"
