                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Grid Margin="0,0,12,8" ColumnDefinitions="96,*">
                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding DisplayName, StringFormat={}{0}:}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <ui:TextBox Grid.Column="1"
                                                        MinWidth="120"
                                                        Margin="8,0,0,0"
                                                        PlaceholderText="{I18N UseCookieEnterHint}"
                                                        Text="{Binding Cookie, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </ui:Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </ui:StackPanel>
                    </ui:CardExpander>
                    <ui:CardExpander>
                        <ui:CardExpander.Header>
                            <ui:Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock MinWidth="26"
                                               Margin="4,0,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                               FontSize="18"
                                               Text="{x:Static ui:FontSymbols.EaseOfAccess}" />
                                </Grid>
                                <ui:Grid Grid.Column="1" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Text="{I18N UserAgent}" />
                                    <TextBlock Grid.Row="1"
                                               FontSize="11"
                                               Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                               Text="{I18N UserAgentHint}" />
                                </ui:Grid>
                                <Grid Grid.Column="2" Margin="0,0,12,0">
                                    <!--  EMPTY  -->
                                </Grid>
                            </ui:Grid>
                        </ui:CardExpander.Header>
                        <ui:StackPanel Spacing="12">
                            <ui:Grid Margin="42,0,28,0" ColumnDefinitions="Auto,*">
                                <TextBlock VerticalAlignment="Center" Text="{I18N UserAgent}" />
                                <ui:TextBox Grid.Column="1"
                                            Margin="8,0,0,0"
                                            PlaceholderText="{I18N UserAgentEnterHint}"
                                            Text="{Binding UserAgent, Mode=TwoWay}" />
                            </ui:Grid>
                        </ui:StackPanel>
                    </ui:CardExpander>
                    <FrameworkElement Height="10" />
                </ui:StackPanel>
            </ScrollViewer>
            <Border Height="6"
                    VerticalAlignment="Top"
                    Panel.ZIndex="20"
                    Background="{DynamicResource EmerdeSurfaceBrush}"
                    IsHitTestVisible="False"
                    OpacityMask="{StaticResource TopEdgeFadeOpacityMask}" />
            <Border Height="6"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="20"
                    Background="{DynamicResource EmerdeSurfaceBrush}"
                    IsHitTestVisible="False"
                    OpacityMask="{StaticResource BottomEdgeFadeOpacityMask}" />
        </ui:Grid>
    </Grid>
</UserControl>
