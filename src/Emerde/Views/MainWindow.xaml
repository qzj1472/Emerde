<ui:FluentWindow x:Class="Emerde.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:b="http://schemas.github.com/computedbehaviors/2024/xaml"
                 xmlns:c="http://schemas.github.com/computedconverters/2024/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                 xmlns:local="clr-namespace:Emerde"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:viewModels="clr-namespace:Emerde.ViewModels"
                 xmlns:views="clr-namespace:Emerde.Views"
                 xmlns:vio="http://schemas.lepo.co/wpfui/2022/xaml/violeta"
                 Title="Emerde"
                 d:Background="#FF101010"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="Manual"
                 mc:Ignorable="d">
    <Grid Background="{DynamicResource EmerdeShellBackgroundBrush}">
        <Grid.Resources>
            <c:ValueConverterGroup x:Key="NotZeroIntToToVisibilityConverter">
                <c:IntToBoolConverter TrueValue="0" />
                <c:BoolToVisibilityConverter />
            </c:ValueConverterGroup>

            <LinearGradientBrush x:Key="TopEdgeFadeOpacityMask" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#FFFFFFFF" />
                <GradientStop Offset="1" Color="#00FFFFFF" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="BottomEdgeFadeOpacityMask" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#00FFFFFF" />
                <GradientStop Offset="1" Color="#FFFFFFFF" />
            </LinearGradientBrush>

            <Style x:Key="StatusTrayButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="MinWidth" Value="28" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSolidNeutralBrush}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="ButtonChrome"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Win11ControlCornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StatusTrayTextBlockStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="StatusTrayIconStyle" TargetType="{x:Type ui:FontIcon}">
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontFamily" Value="{DynamicResource SymbolThemeFontFamily}" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="StatusTrayChipButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Padding" Value="6,0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="ButtonChrome"
                                    Height="{TemplateBinding Height}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Win11ControlCornerRadius}">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StatusTrayCapacityButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Padding" Value="6,0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="ButtonChrome"
                                    MinWidth="{TemplateBinding MinWidth}"
                                    Height="{TemplateBinding Height}"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Win11ControlCornerRadius}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StatusTrayCapacityRefreshButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="MinWidth" Value="28" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="ButtonChrome"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Win11ControlCornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ShellNavButtonStyle" TargetType="{x:Type ToggleButton}">
                <Setter Property="Width" Value="64" />
                <Setter Property="Height" Value="58" />
                <Setter Property="Margin" Value="4,0,4,6" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Grid>
                                <Border x:Name="Chrome"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="{StaticResource Win11ControlCornerRadius}" />
                                <Border x:Name="Indicator"
                                        Width="3"
                                        Height="28"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                        CornerRadius="2"
                                        Opacity="0" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                    <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DetailLabelStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="DetailValueStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="RoomCardChipStyle" TargetType="{x:Type Border}">
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="CornerRadius" Value="{StaticResource Win11ControlCornerRadius}" />
                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="CenteredVerticalScrollBarLineButtonStyle" TargetType="{x:Type RepeatButton}">
                <Setter Property="Width" Value="12" />
                <Setter Property="Height" Value="12" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                            <Border x:Name="ButtonChrome"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource Win11ControlCornerRadius}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CenteredVerticalScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                            <Border Background="Transparent" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CenteredVerticalScrollBarThumbStyle" TargetType="{x:Type Thumb}">
                <Setter Property="MinHeight" Value="24" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                            <Border x:Name="ThumbChrome"
                                    Width="8"
                                    Background="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                    CornerRadius="8"
                                    Opacity="0.65"
                                    SnapsToDevicePixels="True" />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbChrome" Property="Opacity" Value="0.85" />
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbChrome" Property="Opacity" Value="1" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CenteredVerticalScrollBarStyle" TargetType="{x:Type ScrollBar}">
                <Setter Property="Width" Value="12" />
                <Setter Property="MinWidth" Value="12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid Width="{TemplateBinding Width}"
                                  Background="Transparent"
                                  SnapsToDevicePixels="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="12" />
                                </Grid.RowDefinitions>

                                <RepeatButton Grid.Row="0"
                                              Command="{x:Static ScrollBar.LineUpCommand}"
                                              Style="{StaticResource CenteredVerticalScrollBarLineButtonStyle}">
                                    <Path Width="6"
                                          Height="4"
                                          Data="M 0 4 L 3 0 L 6 4 Z"
                                          Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                          Stretch="Fill" />
                                </RepeatButton>

                                <Track x:Name="PART_Track"
                                       Grid.Row="1"
                                       Width="8"
                                       HorizontalAlignment="Center"
                                       IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource CenteredVerticalScrollBarPageButtonStyle}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource CenteredVerticalScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource CenteredVerticalScrollBarPageButtonStyle}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>

                                <RepeatButton Grid.Row="2"
                                              Command="{x:Static ScrollBar.LineDownCommand}"
                                              Style="{StaticResource CenteredVerticalScrollBarLineButtonStyle}">
                                    <Path Width="6"
                                          Height="4"
                                          Data="M 0 0 L 3 4 L 6 0 Z"
                                          Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                          Stretch="Fill" />
                                </RepeatButton>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CenteredVerticalScrollViewerStyle" TargetType="{x:Type ScrollViewer}">
                <Setter Property="Padding" Value="10" />
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollViewer}">
                            <Grid ClipToBounds="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="22" />
                                </Grid.ColumnDefinitions>

                                <ScrollContentPresenter Grid.Column="0"
                                                        Margin="{TemplateBinding Padding}"
                                                        CanContentScroll="{TemplateBinding CanContentScroll}"
                                                        Content="{TemplateBinding Content}"
                                                        ContentTemplate="{TemplateBinding ContentTemplate}" />
                                <ScrollBar x:Name="PART_VerticalScrollBar"
                                           Grid.Column="1"
                                           Width="12"
                                           Margin="5"
                                           HorizontalAlignment="Center"
                                           Maximum="{TemplateBinding ScrollableHeight}"
                                           Minimum="0"
                                           Orientation="Vertical"
                                           Style="{StaticResource CenteredVerticalScrollBarStyle}"
                                           ViewportSize="{TemplateBinding ViewportHeight}"
                                           Value="{TemplateBinding VerticalOffset}"
                                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="RoomCardListBoxStyle" TargetType="{x:Type ListBox}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBox}">
                            <Grid ClipToBounds="True">
                                <ScrollViewer x:Name="RoomCardScrollViewer"
                                              Focusable="False"
                                              Padding="9"
                                              HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                              VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                    <ItemsPresenter />
                                </ScrollViewer>
                                <Border Height="6"
                                        Margin="9,9,22,0"
                                        VerticalAlignment="Top"
                                        Panel.ZIndex="20"
                                        Background="{DynamicResource EmerdePanelBrush}"
                                        IsHitTestVisible="False"
                                        OpacityMask="{StaticResource TopEdgeFadeOpacityMask}" />
                                <Border Height="6"
                                        Margin="9,0,22,9"
                                        VerticalAlignment="Bottom"
                                        Panel.ZIndex="20"
                                        Background="{DynamicResource EmerdePanelBrush}"
                                        IsHitTestVisible="False"
                                        OpacityMask="{StaticResource BottomEdgeFadeOpacityMask}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <ui:Grid x:Name="MainContentRoot" Margin="10,42,10,10" ColumnDefinitions="74,12,*">
            <Border Grid.Column="0"
                    Background="{DynamicResource EmerdeSurfaceBrush}"
                    BorderThickness="0"
                    CornerRadius="{StaticResource Win11ControlCornerRadius}">
                <ui:StackPanel Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               Orientation="Vertical">
                    <ToggleButton Command="{Binding ShowHomePageCommand}"
                                  IsChecked="{Binding IsHomePageSelected, Mode=OneWay}"
                                  Style="{StaticResource ShellNavButtonStyle}">
                        <ui:StackPanel HorizontalAlignment="Center" Spacing="4">
                            <ui:FontIcon HorizontalAlignment="Center"
                                         FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         FontSize="20"
                                         Glyph="{x:Static ui:FontSymbols.Home}" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" Text="首页" />
                        </ui:StackPanel>
                    </ToggleButton>
                    <ToggleButton Command="{Binding OpenScreenRecordListCommand}"
                                  IsChecked="{Binding IsVideoListPageSelected, Mode=OneWay}"
                                  Style="{StaticResource ShellNavButtonStyle}">
                        <ui:StackPanel HorizontalAlignment="Center" Spacing="4">
                            <ui:FontIcon HorizontalAlignment="Center"
                                         FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         FontSize="20"
                                         Glyph="{x:Static ui:FontSymbols.Video}" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" Text="视频列表" />
                        </ui:StackPanel>
                    </ToggleButton>
                    <ToggleButton Command="{Binding OpenSettingsDialogCommand}"
                                  IsChecked="{Binding IsSettingsPageSelected, Mode=OneWay}"
                                  Style="{StaticResource ShellNavButtonStyle}">
                        <ui:StackPanel HorizontalAlignment="Center" Spacing="4">
                            <ui:FontIcon HorizontalAlignment="Center"
                                         FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         FontSize="20"
                                         Glyph="{x:Static ui:FontSymbols.Settings}" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" Text="设置" />
                        </ui:StackPanel>
                    </ToggleButton>
                    <ToggleButton Command="{Binding OpenAboutCommand}"
                                  IsChecked="{Binding IsAboutPageSelected, Mode=OneWay}"
                                  Style="{StaticResource ShellNavButtonStyle}">
                        <ui:StackPanel HorizontalAlignment="Center" Spacing="4">
                            <ui:FontIcon HorizontalAlignment="Center"
                                         FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                         FontSize="20"
                                         Glyph="{x:Static ui:FontSymbols.Info}" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" Text="关于" />
                        </ui:StackPanel>
                    </ToggleButton>
                </ui:StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Background="{DynamicResource EmerdeSurfaceBrush}"
                    BorderThickness="0"
                    CornerRadius="{StaticResource Win11ControlCornerRadius}"
                    Padding="10">
            <Grid x:Name="ShellPageHost">
                <ui:Grid x:Name="HomePageRoot" RowDefinitions="Auto,*,Auto">
                    <ui:Grid.Style>
                        <Style TargetType="{x:Type ui:Grid}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHomePageSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Grid.Style>
            <ui:Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                <ui:StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button MinWidth="72" Command="{Binding AddRoomCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Add}" />
                                <TextBlock Text="{I18N ButtonOfAdd}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding ToggleMonitorCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Radar}">
                                    <ui:FontIcon.Style>
                                        <Style TargetType="{x:Type ui:FontIcon}">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSolidNeutralBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusOfIsMonitorRunning}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:FontIcon.Style>
                                </ui:FontIcon>
                                <TextBlock Text="监控" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding ToggleStatusRecordCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Record}">
                                    <ui:FontIcon.Style>
                                        <Style TargetType="{x:Type ui:FontIcon}">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSolidNeutralBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusOfIsToRecord}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:FontIcon.Style>
                                </ui:FontIcon>
                                <TextBlock Text="{I18N EnableRecord}" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                    <Button MinWidth="72" Command="{Binding ExitApplicationCommand}">
                        <Button.Content>
                            <ui:StackPanel Orientation="Horizontal" Spacing="8">
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                                <TextBlock Text="退出" />
                            </ui:StackPanel>
                        </Button.Content>
                    </Button>
                </ui:StackPanel>

                <FrameworkElement Grid.Column="2" />
            </ui:Grid>

            <ui:Grid Grid.Row="1"
                     Margin="0,8,0,0"
                     ColumnDefinitions="7*,3*">
                <Border Grid.Column="0"
                        x:Name="RoomCardPanel"
                        Padding="0"
                        Background="{DynamicResource EmerdePanelBrush}"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="{StaticResource Win11ControlCornerRadius}"
                        ClipToBounds="True"
                        MouseLeftButtonDown="RoomCardPanelMouseLeftButtonDown"
                        PreviewMouseLeftButtonDown="RoomCardListPreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="RoomCardListPreviewMouseLeftButtonUp"
                        PreviewMouseMove="RoomCardListPreviewMouseMove"
                        PreviewMouseRightButtonDown="RoomCardListPreviewMouseRightButtonDown">
                    <Border.ContextMenu>
                        <ContextMenu Placement="MousePoint" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="卡片大小">
                                <MenuItem Header="大" Click="SetRoomCardLargeClick" />
                                <MenuItem Header="中" Click="SetRoomCardMediumClick" />
                                <MenuItem Header="小" Click="SetRoomCardSmallClick" />
                            </MenuItem>
                            <MenuItem Header="排序">
                                <MenuItem Header="按名称" Command="{Binding SortRoomsByNameCommand}" />
                                <MenuItem Header="按添加顺序" Command="{Binding SortRoomsByAddedAtCommand}" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="刷新" Command="{Binding RefreshRoomCardsCommand}" />
                            <MenuItem Header="编辑模式" Command="{Binding ToggleCardEditModeCommand}" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Grid x:Name="RoomCardPanelContent"
                          ClipToBounds="True"
                          SizeChanged="RoundedPanelContentSizeChanged">
                        <ListBox x:Name="RoomCardList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ClipToBounds="True"
                                 ItemsSource="{Binding RoomStatusesView}"
                                 Loaded="RoomCardListLoaded"
                                 LostMouseCapture="RoomCardListLostMouseCapture"
                                 Padding="0"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 SelectionMode="Single"
                                 SizeChanged="RoomCardListSizeChanged"
                                 Style="{StaticResource RoomCardListBoxStyle}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True"
                                               Width="{Binding RoomCardPanelWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                               HorizontalAlignment="Center"
                                               ItemWidth="{Binding RoomCardItemWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                               ItemHeight="{Binding RoomCardItemHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="ClipToBounds" Value="False" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:RoomStatusReactive}">
                                    <Border x:Name="RoomCardShell"
                                            Width="{Binding RoomCardWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Height="{Binding RoomCardHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Margin="{Binding RoomCardMargin, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Padding="{Binding RoomCardPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                            Background="{DynamicResource EmerdeCardBrush}"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="{StaticResource Win11ControlCornerRadius}"
                                            RenderTransformOrigin="0.5,0.5"
                                            SnapsToDevicePixels="True"
                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                            TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <Border.RenderTransform>
                                            <RotateTransform x:Name="RoomCardAngle" Angle="0" />
                                        </Border.RenderTransform>
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="{I18N PreviewLiveRoom}" Command="{Binding PreviewLiveRoomCommand}" CommandParameter="{Binding SelectedItem}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Play}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N GotoLiveRoom}" Command="{Binding GotoRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.OpenInNewWindow}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N SaveFolder}" Command="{Binding OpenSaveFolderCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.FolderOpen}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="{I18N RowUpRoom}" Command="{Binding RowUpRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.ChevronUp}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N RowDownRoom}" Command="{Binding RowDownRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.ChevronDown}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{I18N StopRecord}" Command="{Binding StopRecordCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Stop}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="{I18N LiveNotification}"
                                                          Command="{Binding IsToNotifyCommand}"
                                                          IsCheckable="True"
                                                          IsChecked="{Binding SelectedItem.IsToNotify, Mode=TwoWay}" />
                                                <MenuItem Header="{I18N EnableRecord}"
                                                          Command="{Binding IsToRecordCommand}"
                                                          IsCheckable="True"
                                                          IsChecked="{Binding SelectedItem.IsToRecord, Mode=TwoWay}" />
                                                <Separator />
                                                <MenuItem Header="{I18N RemoveRoom}" Command="{Binding RemoveRoomUrlCommand}">
                                                    <MenuItem.Icon>
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <ui:Grid ClipToBounds="False" RowDefinitions="Auto,*,Auto">
                                            <ui:Grid Grid.Row="0" ClipToBounds="False">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding RoomCardHeaderColumnWidth, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0"
                                                      Width="{Binding RoomCardAvatarContainerSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      Height="{Binding RoomCardAvatarContainerSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Top"
                                                      Margin="{Binding RoomCardAvatarMargin, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                      ClipToBounds="False">
                                                    <Ellipse Width="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             Height="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Fill="{DynamicResource ControlFillColorDefaultBrush}" />
                                                    <Ellipse x:Name="RoomCardAvatarImage"
                                                             Width="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             Height="{Binding RoomCardAvatarSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             RenderOptions.BitmapScalingMode="HighQuality"
                                                             SnapsToDevicePixels="True">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding AvatarDisplaySource}" Stretch="UniformToFill" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock x:Name="RoomCardAvatarPlaceholder"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="{Binding RoomCardAvatarIconSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               Text="&#xE77B;"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed" />
                                                </Grid>
                                                <ui:StackPanel Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Spacing="2">
                                                    <TextBlock FontSize="{Binding RoomCardNameFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding NickName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="{Binding RoomCardPlatformFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding PlatformDisplayName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </ui:StackPanel>
                                            </ui:Grid>

                                            <TextBlock Grid.Row="1"
                                                       Margin="0,5,0,0"
                                                       FontSize="{Binding RoomCardTitleFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       LineHeight="{Binding RoomCardTitleLineHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       MaxHeight="{Binding RoomCardTitleMaxHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                       Text="{Binding LiveTitleText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding RoomCardTitleVisibility, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}" />

                                            <ui:Grid Grid.Row="2"
                                                     Margin="0,6,0,0"
                                                     VerticalAlignment="Bottom"
                                                     ColumnDefinitions="*,*">
                                                <Border Grid.Column="0"
                                                        Margin="0,0,4,0"
                                                        Height="{Binding RoomCardChipMinHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Padding="{Binding RoomCardChipPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Style="{StaticResource RoomCardChipStyle}">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="{Binding RoomCardChipFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               Text="{Binding StreamStatusText}"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                                <Border Grid.Column="1"
                                                        Margin="4,0,0,0"
                                                        Height="{Binding RoomCardChipMinHeight, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Padding="{Binding RoomCardChipPadding, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                        Style="{StaticResource RoomCardChipStyle}">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="{Binding RoomCardChipFontSize, RelativeSource={RelativeSource AncestorType={x:Type views:MainWindow}}}"
                                                               Text="{Binding RecordStatusText}"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </ui:Grid>
                                        </ui:Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True" />
                                                <Condition Binding="{Binding DataContext.IsRoomCardSelectionVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="RoomCardShell" Property="Background" Value="#2A4DA7B0" />
                                            <Setter TargetName="RoomCardShell" Property="BorderBrush" Value="#884DA7B0" />
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsRefreshFlashActive}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="RoomCardShell"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         From="0.55"
                                                                         To="1"
                                                                         Duration="0:0:0.34" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AvatarDisplaySource}" Value="">
                                            <Setter TargetName="RoomCardAvatarImage" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="RoomCardAvatarPlaceholder" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.IsCardEditMode, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RoomCardWiggleStoryboard">
                                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetName="RoomCardAngle"
                                                                         Storyboard.TargetProperty="Angle"
                                                                         From="-0.45"
                                                                         To="0.45"
                                                                         Duration="0:0:0.12"
                                                                         FillBehavior="Stop" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RoomCardWiggleStoryboard" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ui:StackPanel HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.8"
                                       Spacing="8"
                                       Visibility="{Binding RoomStatuses.Count, Converter={StaticResource NotZeroIntToToVisibilityConverter}}">
                            <ui:FontIcon FontFamily="{DynamicResource CustomSymbolThemeFontFamily}"
                                         FontSize="40"
                                         Glyph="{x:Static ui:CustomFontSymbols.Empty}" />
                            <TextBlock Text="{I18N EmptyRoomHint}" />
                        </ui:StackPanel>
                        <Border Height="6"
                                VerticalAlignment="Top"
                                Panel.ZIndex="20"
                                Background="{DynamicResource EmerdePanelBrush}"
                                IsHitTestVisible="False"
                                OpacityMask="{StaticResource TopEdgeFadeOpacityMask}" />
                        <Border Height="6"
                                VerticalAlignment="Bottom"
                                Panel.ZIndex="20"
                                Background="{DynamicResource EmerdePanelBrush}"
                                IsHitTestVisible="False"
                                OpacityMask="{StaticResource BottomEdgeFadeOpacityMask}" />
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="8,0,0,0"
                        Padding="0"
                        Background="{DynamicResource EmerdePanelBrush}"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="{StaticResource Win11ControlCornerRadius}"
                        ClipToBounds="True">
                    <Grid x:Name="RoomDetailPanelContent"
                          ClipToBounds="True"
                          SizeChanged="RoundedPanelContentSizeChanged">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  Padding="10"
                                  VerticalScrollBarVisibility="Visible">
                        <StackPanel Margin="0">
                            <ui:Grid ColumnDefinitions="Auto,*">
                                <vio:PersonPicture Grid.Column="0"
                                                   Width="44"
                                                   Height="44"
                                                   DisplayName="{Binding SelectedItem.NickName}"
                                                   ProfilePicture="{Binding SelectedItem.AvatarDisplaySource}"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   SnapsToDevicePixels="True" />
                                <StackPanel Grid.Column="1"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedItem.NickName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,3,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding SelectedItem.RoomCodeText, StringFormat=UID: {0}}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </ui:Grid>

                            <Border Height="1"
                                    Margin="0,16,0,16"
                                    Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    Opacity="0.65" />

                            <ui:Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                           Text="直播间信息" />
                                <Button Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        MinWidth="28"
                                        Padding="0"
                                        Command="{Binding RefreshSelectedRoomInfoCommand}"
                                        ToolTip="刷新">
                                    <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                 Glyph="{x:Static ui:FontSymbols.Sync}"
                                                 RenderTransformOrigin="0.5,0.5">
                                        <ui:FontIcon.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </ui:FontIcon.RenderTransform>
                                        <ui:FontIcon.Style>
                                            <Style TargetType="{x:Type ui:FontIcon}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRefreshingSelectedRoomInfo}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="SelectedRoomRefreshStoryboard">
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                     From="0"
                                                                                     To="360"
                                                                                     Duration="0:0:0.75" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="SelectedRoomRefreshStoryboard" />
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:FontIcon.Style>
                                    </ui:FontIcon>
                                </Button>
                            </ui:Grid>

                            <ui:Grid ColumnDefinitions="74,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="{I18N Platform}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.PlatformDisplayName}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="标题" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.LiveTitleText}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="{I18N StreamStatus}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.StreamStatusText}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="{I18N RecordStatus}" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.RecordStatusText}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="录制格式" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource DetailValueStyle}" Text="{Binding StatusOfRecordFormat}" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="画质" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.QualityText}" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="分辨率" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.ResolutionText}" />

                                <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="码率" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,0,0,10" Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.BitrateText}" />

                                <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,0,12,10" Style="{StaticResource DetailLabelStyle}" Text="房间地址" />
                                <ui:Grid Grid.Row="8" Grid.Column="1" Margin="0,0,0,10" ColumnDefinitions="*,Auto">
                                    <TextBlock Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.RoomUrl}" />
                                    <Button Grid.Column="1"
                                            Width="28"
                                            Height="28"
                                            MinWidth="28"
                                            Margin="8,0,0,0"
                                            Padding="0"
                                            Command="{Binding CopySelectedRoomUrlCommand}"
                                            ToolTip="复制">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Copy}" />
                                    </Button>
                                </ui:Grid>

                                <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,0,12,0" Style="{StaticResource DetailLabelStyle}" Text="直播流" />
                                <ui:Grid Grid.Row="9" Grid.Column="1" ColumnDefinitions="*,Auto">
                                    <TextBlock Style="{StaticResource DetailValueStyle}" Text="{Binding SelectedItem.LiveStreamText}" />
                                    <Button Grid.Column="1"
                                            Width="28"
                                            Height="28"
                                            MinWidth="28"
                                            Margin="8,0,0,0"
                                            Padding="0"
                                            Command="{Binding CopySelectedPreviewUrlCommand}"
                                            ToolTip="复制">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Copy}" />
                                    </Button>
                                </ui:Grid>
                            </ui:Grid>

                            <Border Height="1"
                                    Margin="0,18,0,16"
                                    Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    Opacity="0.65" />

                            <TextBlock Margin="0,0,0,10"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                       Text="操作" />
                            <WrapPanel>
                                <Button MinWidth="76"
                                        Margin="0,0,8,8"
                                        Command="{Binding PreviewLiveRoomCommand}"
                                        CommandParameter="{Binding SelectedItem}"
                                        IsEnabled="{Binding CanPreviewSelectedRoom}">
                                    <ui:StackPanel Orientation="Horizontal" Spacing="6">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Play}" />
                                        <TextBlock Text="{I18N PreviewLiveRoom}" />
                                    </ui:StackPanel>
                                </Button>
                                <Button MinWidth="76"
                                        Margin="0,0,8,8"
                                        Command="{Binding GotoRoomUrlCommand}">
                                    <ui:StackPanel Orientation="Horizontal" Spacing="6">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.OpenInNewWindow}" />
                                        <TextBlock Text="{I18N ButtonOfGoto}" />
                                    </ui:StackPanel>
                                </Button>
                                <Button MinWidth="76"
                                        Margin="0,0,8,8"
                                        Command="{Binding ToggleSelectedRoomMonitorCommand}">
                                    <ui:StackPanel Orientation="Horizontal" Spacing="6">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Radar}">
                                            <ui:FontIcon.Style>
                                                <Style TargetType="{x:Type ui:FontIcon}">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSolidNeutralBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem.EffectiveIsToMonitor}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:FontIcon.Style>
                                        </ui:FontIcon>
                                        <TextBlock Text="监控" />
                                    </ui:StackPanel>
                                </Button>
                                <Button MinWidth="76"
                                        Margin="0,0,8,8"
                                        Command="{Binding ToggleSelectedRoomRecordCommand}">
                                    <ui:StackPanel Orientation="Horizontal" Spacing="6">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Record}">
                                            <ui:FontIcon.Style>
                                                <Style TargetType="{x:Type ui:FontIcon}">
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSolidNeutralBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem.EffectiveIsToRecord}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:FontIcon.Style>
                                        </ui:FontIcon>
                                        <TextBlock Text="{I18N EnableRecord}" />
                                    </ui:StackPanel>
                                </Button>
                                <Button MinWidth="76"
                                        Margin="0,0,8,8"
                                        Command="{Binding OpenLocalSettingsCommand}">
                                    <ui:StackPanel Orientation="Horizontal" Spacing="6">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.Settings}" />
                                        <TextBlock Text="设置" />
                                    </ui:StackPanel>
                                </Button>
                                <Button MinWidth="76"
                                        Margin="0,0,8,8"
                                        Command="{Binding RemoveRoomUrlCommand}">
                                    <ui:StackPanel Orientation="Horizontal" Spacing="6">
                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="{x:Static ui:FontSymbols.CalculatorMultiply}" />
                                        <TextBlock Text="{I18N RemoveRoom}" />
                                    </ui:StackPanel>
                                </Button>
                            </WrapPanel>

                            <UniformGrid Columns="1" Margin="0,10,0,0">
                                <CheckBox Command="{Binding IsToNotifyCommand}"
                                          Content="{I18N LiveNotification}"
                                          IsChecked="{Binding SelectedItem.IsToNotify, Mode=TwoWay}" />
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Height="6"
                            VerticalAlignment="Top"
                            Panel.ZIndex="20"
                            Background="{DynamicResource EmerdePanelBrush}"
                            IsHitTestVisible="False"
                            OpacityMask="{StaticResource TopEdgeFadeOpacityMask}" />
                    <Border Height="6"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="20"
                            Background="{DynamicResource EmerdePanelBrush}"
                            IsHitTestVisible="False"
                            OpacityMask="{StaticResource BottomEdgeFadeOpacityMask}" />
                    </Grid>
                </Border>
            </ui:Grid>

            <ui:Grid Grid.Row="2"
                     Height="28"
                     Margin="0,4,0,0"
                     SnapsToDevicePixels="True"
                     UseLayoutRounding="True"
                     VerticalAlignment="Center"
                     ColumnDefinitions="Auto,*,Auto">
                <ui:StackPanel Grid.Column="0"
                               Height="28"
                               VerticalAlignment="Center"
                               Orientation="Horizontal"
                               Spacing="8">
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource StatusTrayTextBlockStyle}"
                               Text="{Binding PlatformSummaryText}" />
                    <ui:StackPanel VerticalAlignment="Center"
                                   Orientation="Horizontal"
                                   Spacing="2">
                        <Button Command="{Binding TestNetworkCapacityCommand}"
                                Style="{StaticResource StatusTrayCapacityButtonStyle}"
                                ToolTip="{Binding NetworkCapacityToolTip}">
                            <ui:StackPanel VerticalAlignment="Center"
                                           Orientation="Horizontal"
                                           Spacing="5">
                                <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                             Glyph="{x:Static ui:FontSymbols.Globe}" />
                                <TextBlock FontWeight="SemiBold"
                                           Style="{StaticResource StatusTrayTextBlockStyle}"
                                           Text="{Binding NetworkCapacityDisplayText}"
                                           TextTrimming="CharacterEllipsis" />
                            </ui:StackPanel>
                        </Button>
                        <Button Command="{Binding TestNetworkCapacityCommand}"
                                Style="{StaticResource StatusTrayCapacityRefreshButtonStyle}"
                                ToolTip="{Binding NetworkCapacityToolTip}">
                            <ui:FontIcon Glyph="{x:Static ui:FontSymbols.Sync}"
                                         RenderTransformOrigin="0.5,0.5">
                                <ui:FontIcon.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </ui:FontIcon.RenderTransform>
                                <ui:FontIcon.Style>
                                    <Style BasedOn="{StaticResource StatusTrayIconStyle}" TargetType="{x:Type ui:FontIcon}">
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNetworkCapacityTesting}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="NetworkCapacityRefreshStoryboard">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0"
                                                                             To="360"
                                                                             Duration="0:0:0.75" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="NetworkCapacityRefreshStoryboard" />
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:FontIcon.Style>
                            </ui:FontIcon>
                        </Button>
                    </ui:StackPanel>
                </ui:StackPanel>
                <ui:StackPanel Grid.Column="2"
                               Height="28"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Opacity="0.9"
                               Orientation="Horizontal"
                               Spacing="8">
                        <Button Command="{Binding ToggleMonitorCommand}"
                                Style="{StaticResource StatusTrayButtonStyle}"
                                ToolTip="监控">
                            <c:If Condition="{Binding StatusOfIsMonitorRunning, Mode=OneWay}">
                                <c:If.TrueValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Radar}" />
                                </c:If.TrueValue>
                                <c:If.FalseValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Radar}" />
                                </c:If.FalseValue>
                            </c:If>
                        </Button>
                        <Button Command="{Binding ToggleStatusNotifyCommand}"
                                Style="{StaticResource StatusTrayButtonStyle}"
                                ToolTip="{I18N LiveNotification}">
                            <c:If Condition="{Binding StatusOfIsToNotify, Mode=OneWay}">
                                <c:If.TrueValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Ringer}" />
                                </c:If.TrueValue>
                                <c:If.FalseValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Ringer}" />
                                </c:If.FalseValue>
                            </c:If>
                        </Button>
                        <Button Command="{Binding ToggleStatusRecordCommand}"
                                Style="{StaticResource StatusTrayButtonStyle}"
                                ToolTip="{I18N EnableRecord}">
                            <c:If Condition="{Binding StatusOfIsToRecord, Mode=OneWay}">
                                <c:If.TrueValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Video}" />
                                </c:If.TrueValue>
                                <c:If.FalseValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Video}" />
                                </c:If.FalseValue>
                            </c:If>
                        </Button>
                        <Button Command="{Binding ToggleStatusProxyCommand}"
                                Style="{StaticResource StatusTrayButtonStyle}"
                                ToolTip="{I18N UseProxy}">
                            <c:If Condition="{Binding StatusOfIsUseProxy, Mode=OneWay}">
                                <c:If.TrueValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.VPN}" />
                                </c:If.TrueValue>
                                <c:If.FalseValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.VPN}" />
                                </c:If.FalseValue>
                            </c:If>
                        </Button>
                        <Button Command="{Binding ToggleStatusKeepAwakeCommand}"
                                Style="{StaticResource StatusTrayButtonStyle}"
                                ToolTip="{I18N KeepAwake}">
                            <c:If Condition="{Binding StatusOfIsUseKeepAwake, Mode=OneWay}">
                                <c:If.TrueValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Recent}" />
                                </c:If.TrueValue>
                                <c:If.FalseValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.Recent}" />
                                </c:If.FalseValue>
                            </c:If>
                        </Button>
                        <Button Command="{Binding ToggleStatusAutoShutdownCommand}"
                                Style="{StaticResource StatusTrayButtonStyle}"
                                ToolTip="{I18N AutoShutdown}">
                            <c:If Condition="{Binding StatusOfIsUseAutoShutdown, Mode=OneWay}">
                                <c:If.TrueValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                                </c:If.TrueValue>
                                <c:If.FalseValue>
                                    <ui:FontIcon Style="{StaticResource StatusTrayIconStyle}"
                                                 Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                                                 Glyph="{x:Static ui:FontSymbols.PowerButton}" />
                                </c:If.FalseValue>
                            </c:If>
                        </Button>
                        <TextBlock Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                   Style="{StaticResource StatusTrayTextBlockStyle}"
                                   Text="{Binding StatusOfAutoShutdownTime}"
                                   ToolTip="{I18N AutoShutdown}"
                                   Visibility="{Binding StatusOfIsUseAutoShutdown, Converter={x:Static c:BoolToVisibilityConverter.Instance}}" />
                        <Border Width="1"
                                Height="14"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                Opacity="0.55" />
                        <Button Command="{Binding OpenSettingsDialogCommand}"
                                Style="{StaticResource StatusTrayChipButtonStyle}"
                                ToolTip="{I18N RoutineInterval}">
                            <TextBlock Style="{StaticResource StatusTrayTextBlockStyle}"
                                       Text="{Binding StatusOfRoutineIntervalWithUnit}" />
                        </Button>
                        <Border Width="1"
                                Height="14"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                Opacity="0.55" />
                        <TextBlock Opacity="0.6"
                                   Style="{StaticResource StatusTrayTextBlockStyle}"
                                   Text="{Binding StatusOfRecordFormat}"
                                   ToolTip="{I18N RecordFormat}" />
                </ui:StackPanel>
            </ui:Grid>
                </ui:Grid>

                <views:ScreenRecordListWindow>
                    <views:ScreenRecordListWindow.Style>
                        <Style TargetType="{x:Type views:ScreenRecordListWindow}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsVideoListPageSelected, ElementName=ShellPageHost}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:ScreenRecordListWindow.Style>
                </views:ScreenRecordListWindow>

                <views:SettingsWindow>
                    <views:SettingsWindow.Style>
                        <Style TargetType="{x:Type views:SettingsWindow}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsSettingsPageSelected, ElementName=ShellPageHost}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:SettingsWindow.Style>
                </views:SettingsWindow>

                <views:AboutContentDialog>
                    <views:AboutContentDialog.Style>
                        <Style TargetType="{x:Type views:AboutContentDialog}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsAboutPageSelected, ElementName=ShellPageHost}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </views:AboutContentDialog.Style>
                </views:AboutContentDialog>
            </Grid>
            </Border>
        </ui:Grid>

        <Grid x:Name="MainDialogOverlay"
              Background="Transparent"
              IsHitTestVisible="False"
              Panel.ZIndex="40"
              Visibility="Collapsed" />

        <Grid>
            <ui:TitleBar Height="32" Title="{I18N Title}" ShowMaximize="True">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Assets/Favicon.png" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </Grid>
    </Grid>
</ui:FluentWindow>
