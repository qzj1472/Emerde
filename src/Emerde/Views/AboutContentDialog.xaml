<UserControl x:Class="Emerde.Views.AboutContentDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:base="clr-namespace:Emerde"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             FontSize="14"
             mc:Ignorable="d">
    <Grid ClipToBounds="True">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Border Padding="18">
            <ui:StackPanel Spacing="18">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="{I18N About}" />

            <Grid MaxWidth="760" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="72"
                        Height="72"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="{StaticResource Win11ControlCornerRadius}"
                        ClipToBounds="True">
                    <Image Width="72"
                           Height="72"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="pack://application:,,,/Assets/Favicon.png"
                           Stretch="UniformToFill" />
                </Border>

                <ui:StackPanel Grid.Column="1"
                               Margin="18,0,0,0"
                               VerticalAlignment="Center"
                               Spacing="7">
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="{x:Static base:AppConfig.PackName}" />
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{x:Static base:AppConfig.Version}" />
                    <ui:HyperlinkButton Command="{Binding OpenHyperlinkCommand}"
                                        Content="{x:Static base:AppConfig.Url}"
                                        Cursor="Hand"
                                        Padding="0" />
                </ui:StackPanel>
            </Grid>

            <UniformGrid MaxWidth="1040"
                         HorizontalAlignment="Left"
                         Columns="2">
                <Border Margin="0,0,10,10"
                        Padding="18"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="{StaticResource Win11ControlCornerRadius}">
                    <ui:StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="快速开始" />
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   LineHeight="20"
                                   Text="解压后即可使用，不建议放在 C 盘。&#x0a;在首页点击新建，添加直播间链接。&#x0a;软件会按监控周期检查直播状态，判断开播后自动录制。"
                                   TextWrapping="Wrap" />
                    </ui:StackPanel>
                </Border>

                <Border Margin="10,0,0,10"
                        Padding="18"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="{StaticResource Win11ControlCornerRadius}">
                    <ui:StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="监控与录制" />
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   LineHeight="20"
                                   Text="顶部监控和录制是总开关。&#x0a;单个直播间可以在局部设置中覆盖全局设置。&#x0a;默认循环周期为 3 秒，可在设置页调整。"
                                   TextWrapping="Wrap" />
                    </ui:StackPanel>
                </Border>

                <Border Margin="0,10,10,0"
                        Padding="18"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="{StaticResource Win11ControlCornerRadius}">
                    <ui:StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="日志与排查" />
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   LineHeight="20"
                                   Text="运行日志建议保持开启。&#x0a;遇到问题时请导出日志，并说明直播间链接、操作步骤和异常现象。&#x0a;不要只描述结果，日志能直接定位失败位置。"
                                   TextWrapping="Wrap" />
                    </ui:StackPanel>
                </Border>

                <Border Margin="10,10,0,0"
                        Padding="18"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        CornerRadius="{StaticResource Win11ControlCornerRadius}">
                    <ui:StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="网络与格式" />
                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   LineHeight="20"
                                   Text="单路直播通常约需要 10 Mbps，网络不足时不要同时添加过多直播间。&#x0a;左下角测速会估算可同时录制路数。&#x0a;录制格式默认使用 TS/FLV 转 MKV，如需兼容性可选择转 MP4。"
                                   TextWrapping="Wrap" />
                    </ui:StackPanel>
                </Border>
            </UniformGrid>
            </ui:StackPanel>
            </Border>
        </ScrollViewer>
        <Border Height="6"
                VerticalAlignment="Top"
                Panel.ZIndex="20"
                Background="{DynamicResource EmerdeSurfaceBrush}"
                IsHitTestVisible="False"
                OpacityMask="{StaticResource TopEdgeFadeOpacityMask}" />
        <Border Height="6"
                VerticalAlignment="Bottom"
                Panel.ZIndex="20"
                Background="{DynamicResource EmerdeSurfaceBrush}"
                IsHitTestVisible="False"
                OpacityMask="{StaticResource BottomEdgeFadeOpacityMask}" />
    </Grid>
</UserControl>
