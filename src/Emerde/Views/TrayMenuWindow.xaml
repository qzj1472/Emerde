<Window x:Class="Emerde.Views.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1"
        Height="1"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="TrayMenuItemStyle"
               TargetType="{x:Type MenuItem}"
               BasedOn="{StaticResource {x:Type MenuItem}}">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style x:Key="PrimaryTrayMenuItemStyle"
               TargetType="{x:Type MenuItem}"
               BasedOn="{StaticResource TrayMenuItemStyle}">
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="ToggleTrayMenuItemStyle"
               TargetType="{x:Type MenuItem}"
               BasedOn="{StaticResource TrayMenuItemStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid x:Name="PlacementTarget">
        <Grid.ContextMenu>
            <ContextMenu x:Name="TrayContextMenu"
                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                         MinWidth="176"
                         Closed="TrayContextMenuClosed"
                         Opened="TrayContextMenuOpened"
                         Placement="Custom"
                         StaysOpen="False">
                <MenuItem Click="ShowMainWindowClick"
                          Header="{Binding ShowMainWindowText}"
                          Style="{StaticResource PrimaryTrayMenuItemStyle}" />
                <MenuItem Click="OpenSettingsClick"
                          Header="{Binding SettingsText}"
                          Style="{StaticResource TrayMenuItemStyle}" />

                <Separator />

                <MenuItem Click="ToggleMonitorClick"
                          Header="{Binding MonitorText}"
                          IsCheckable="True"
                          IsChecked="{Binding IsMonitorRunning, Mode=OneWay}"
                          Style="{StaticResource ToggleTrayMenuItemStyle}" />
                <MenuItem Click="ToggleRecordClick"
                          Header="{Binding RecordText}"
                          IsCheckable="True"
                          IsChecked="{Binding IsRecordEnabled, Mode=OneWay}"
                          Style="{StaticResource ToggleTrayMenuItemStyle}" />
                <MenuItem Click="ToggleAutoRunClick"
                          Header="{Binding AutoRunText}"
                          IsCheckable="True"
                          IsChecked="{Binding IsAutoRun, Mode=OneWay}"
                          Style="{StaticResource ToggleTrayMenuItemStyle}" />

                <Separator />

                <MenuItem Click="RestartClick"
                          Header="{Binding RestartText}"
                          Style="{StaticResource TrayMenuItemStyle}" />
                <MenuItem Click="ExitClick"
                          Header="{Binding ExitText}"
                          Style="{StaticResource TrayMenuItemStyle}" />
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
